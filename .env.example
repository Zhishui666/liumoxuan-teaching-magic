# Volcengine Doubao Streaming ASR
# Copy this file to .env locally, then fill in your own values.
# Never commit .env or real API keys.

# Required by newer Volcengine console projects.
VOLCENGINE_ASR_API_KEY=

# Optional compatibility for App Key + Access Key projects.
VOLCENGINE_ASR_APP_KEY=
VOLCENGINE_ASR_ACCESS_KEY=

# Streaming ASR endpoint and resource id.
VOLCENGINE_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
VOLCENGINE_ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# Recommended streaming audio settings.
VOLCENGINE_ASR_AUDIO_FORMAT=wav
VOLCENGINE_ASR_SAMPLE_RATE=16000
VOLCENGINE_ASR_BITS=16
VOLCENGINE_ASR_CHANNELS=1
VOLCENGINE_ASR_CHUNK_MS=200

# Optional. Local PCM/WAV file for smoke tests.
VOLCENGINE_ASR_TEST_AUDIO_PATH=

# Optional user id passed to the ASR API.
VOLCENGINE_ASR_UID=liumoxuan-teaching-magic
